<!DOCTYPE html>
<html>
    <head>
        <title>JTH Calendar Generator</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet"> 
        <style>
            body {
                font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
                
                color: #222;
                background-color: #fefefe;
            }

            input {
                border: 1px solid #ccc;
                border-radius: 4px;
                padding: 0.5rem;
                font-family: inherit;
                color: inherit;
            }

            select, button {
                font-family: inherit;
                border: 1px solid #ccc;
                border-radius: 4px;
                padding: 0.5rem;
            }

            form {
                display: flex;
                gap: 1rem;
            }

            a {
                color: #0070f3;
                text-decoration: none;
            }

            

            a:hover {
                text-decoration: underline;
            }

            label span::after {
                content: ':';
            }

            div#calendar {
                max-width: max-content;
            }
            div.months {
                display: flex;
                flex-wrap: wrap;
                gap: 1rem;
            }

            table {
                table-layout: fixed;
                border: 1px solid currentColor;
                border-collapse: collapse;
            }

            th {
                padding: 0 0.5rem;
            }

            td, th {
                font-variant-numeric: tabular-nums;
                text-align: center;
                width: 10%;
            }

            td:empty {
                background-color: #eee;
            }

            .month-name {
                border-bottom: 1px solid currentColor;
            }

            @media screen and (prefers-color-scheme: dark) {
                body {
                    color: #eee;
                    background-color: #222;
                }

                a {
                    color: #7fbaff;
                }

                input {
                    border-color: #777;
                    background-color: #444;
                }

                td:empty {
                    background-color: #444;
                }
            }
        </style>
        <script defer src="assets/static/calendar.js"></script>
    </head>
    <body>
        <main>
            <h1>
                Jotunnheim Calendar Generator
            </h1>
            <p>
                Generates a calendar according to year, and optionally month based upon the
                <a href="https://maruneko.autumns.page/mediawiki/index.php/Marphat_calendar">Marphat Calendar</a>.
            </p>
            <noscript>
                <p>
                    This page requires JavaScript to function. Please enable it in your browser.
                </p>
            </noscript>
            <form id="form">
                <label>
                    <span>Year</span>
                    <input type="number" id="year" placeholder="Year" required value="4627">
                </label>
                <label>
                    <span>Month (optional)</span>
                    <select id="month">
                        <option value="0">Full year</option>
                        <option value="1">Massaigh</option>
                        <option value="2">Aisser</option>
                        <option value="3">Baimither</option>
                        <option value="4">Tocha</option>
                        <option value="5">Sacha</option>
                        <option value="6">Taime</option>
                        <option value="7">Giulan</option>
                        <option value="8">Uinte</option>
                        <option value="9">Cubhaigh</option>
                        <option value="10">Bomaigh</option>
                    </select>
                </label>
                <button type="submit">Generate</button>
            </form>
            
            <div id="calendar"></div>
        </main>
    </body>
</html>